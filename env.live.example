# BulletTrade 实盘最小示例
# 先只填必须项，其他都先不要加。

# =========================
# 本地 QMT 最小配置
# =========================

DEFAULT_DATA_PROVIDER=qmt
DEFAULT_BROKER=qmt
QMT_DATA_PATH=C:\国金QMT交易端\userdata_mini
QMT_ACCOUNT_ID=123456

# 如果是期货账户，再加这一行：
# QMT_ACCOUNT_TYPE=future

# =========================
# 远程 qmt-remote 客户端
# =========================
# 如果你不是本地 QMT，而是连远程 server，
# 把上面的 DEFAULT_BROKER 改成 qmt-remote，
# 然后填下面这几个：
#
# DEFAULT_DATA_PROVIDER=qmt-remote
# DEFAULT_BROKER=qmt-remote
# QMT_SERVER_HOST=10.0.0.8
# QMT_SERVER_PORT=58620
# QMT_SERVER_TOKEN=secret
#
# 单账户时不用写 QMT_SERVER_ACCOUNT_KEY。
# 如果策略通过上层调度网关运行，这里的 58620 仍是 bullet-trade server 端口；
# 上层网关自己的端口应写在上层系统配置中，不要填到 QMT_SERVER_PORT。

# =========================
# 远程 server（Windows）
# =========================
# 如果这台机器是 QMT 所在机器，需要启动 bullet-trade server，
# 再加这一行：
#
# QMT_SERVER_TOKEN=secret
#
# 启动命令：
# bullet-trade --env-file .env server --listen 0.0.0.0 --port 58620 --enable-data --enable-broker

# =========================
# 这些先不要配
# =========================
# LOG_DIR
# RUNTIME_DIR
# QMT_SESSION_ID
# QMT_AUTO_SUBSCRIBE
# QMT_SERVER_ACCOUNT_KEY
# 风控参数
# MIN_BUY_ORDER_VALUE=0  # 最小买入订单金额；0 表示不限制，仅在风控开启时生效
# TRADE_MAX_WAIT_TIME=16  # 实盘下单同步等待秒数；0=异步不等待
